#!/bin/bash
# ─────────────────────────────────────────────────────────────────────────────
# nginx-pgsql — Service management for Nginx + PHP-FPM + PostgreSQL
# Environment: openSUSE Leap 16.0 (no systemd)
# ─────────────────────────────────────────────────────────────────────────────

set -euo pipefail

PG_DATA="/var/lib/pgsql/data"
PG_USER="postgres"
PHP_FPM_BIN="/usr/sbin/php-fpm"
PHP_FPM_CONF="/etc/php8/fpm/php-fpm.conf"
PHP_FPM_PID="/run/php-fpm/php-fpm.pid"
PHP_FPM_SOCK="/run/php-fpm/php-fpm.sock"
NGINX_BIN="/sbin/nginx"
NGINX_PID="/run/nginx.pid"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

log_info()  { echo -e "${CYAN}[INFO]${NC}  $*"; }
log_ok()    { echo -e "${GREEN}[OK]${NC}    $*"; }
log_warn()  { echo -e "${YELLOW}[WARN]${NC}  $*"; }
log_err()   { echo -e "${RED}[ERROR]${NC} $*"; }

# ── Helpers ───────────────────────────────────────────────────────────────────

is_running() {
    local pidfile="$1"
    if [[ -f "$pidfile" ]]; then
        local pid
        pid=$(cat "$pidfile" 2>/dev/null)
        if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
            return 0
        fi
    fi
    return 1
}

wait_for_pid() {
    local pidfile="$1" timeout="${2:-10}" elapsed=0
    while [[ $elapsed -lt $timeout ]]; do
        if is_running "$pidfile"; then
            return 0
        fi
        sleep 0.5
        elapsed=$((elapsed + 1))
    done
    return 1
}

wait_for_stop() {
    local pidfile="$1" timeout="${2:-10}" elapsed=0
    while [[ $elapsed -lt $timeout ]]; do
        if ! is_running "$pidfile"; then
            return 0
        fi
        sleep 0.5
        elapsed=$((elapsed + 1))
    done
    return 1
}

# ── PostgreSQL ────────────────────────────────────────────────────────────────

pg_start() {
    log_info "Starting PostgreSQL..."
    if su - "$PG_USER" -c "pg_ctl -D $PG_DATA status" &>/dev/null; then
        log_warn "PostgreSQL is already running."
    else
        su - "$PG_USER" -c "pg_ctl -D $PG_DATA start -w -t 60 -l /var/lib/pgsql/data/log/postgresql.log"
        log_ok "PostgreSQL started."
    fi
}

pg_stop() {
    log_info "Stopping PostgreSQL..."
    if su - "$PG_USER" -c "pg_ctl -D $PG_DATA status" &>/dev/null; then
        su - "$PG_USER" -c "pg_ctl -D $PG_DATA stop -m fast"
        log_ok "PostgreSQL stopped."
    else
        log_warn "PostgreSQL is not running."
    fi
}

# ── PHP-FPM ───────────────────────────────────────────────────────────────────

fpm_start() {
    log_info "Starting PHP-FPM..."
    if is_running "$PHP_FPM_PID"; then
        log_warn "PHP-FPM is already running (PID: $(cat "$PHP_FPM_PID"))."
        return 0
    fi

    # Ensure runtime directory exists
    mkdir -p /run/php-fpm
    chown nginx:nginx /run/php-fpm

    "$PHP_FPM_BIN" --fpm-config "$PHP_FPM_CONF" --daemonize
    if wait_for_pid "$PHP_FPM_PID" 10; then
        log_ok "PHP-FPM started (PID: $(cat "$PHP_FPM_PID"))."
    else
        log_err "PHP-FPM failed to start. Check /var/log/php-fpm.log"
        return 1
    fi
}

fpm_stop() {
    log_info "Stopping PHP-FPM..."
    if is_running "$PHP_FPM_PID"; then
        kill -QUIT "$(cat "$PHP_FPM_PID")"
        if wait_for_stop "$PHP_FPM_PID" 10; then
            log_ok "PHP-FPM stopped."
        else
            log_warn "PHP-FPM did not stop gracefully, sending SIGKILL..."
            kill -9 "$(cat "$PHP_FPM_PID")" 2>/dev/null || true
            rm -f "$PHP_FPM_PID" "$PHP_FPM_SOCK"
            log_ok "PHP-FPM killed."
        fi
    else
        log_warn "PHP-FPM is not running."
        # Clean up stale socket
        rm -f "$PHP_FPM_SOCK"
    fi
}

# ── Nginx ─────────────────────────────────────────────────────────────────────

nginx_start() {
    log_info "Starting Nginx..."
    if is_running "$NGINX_PID"; then
        log_warn "Nginx is already running (PID: $(cat "$NGINX_PID"))."
        return 0
    fi

    # Validate config first
    if ! "$NGINX_BIN" -t 2>&1; then
        log_err "Nginx configuration test failed. Aborting."
        return 1
    fi

    "$NGINX_BIN"
    if wait_for_pid "$NGINX_PID" 10; then
        log_ok "Nginx started (PID: $(cat "$NGINX_PID"))."
    else
        log_err "Nginx failed to start. Check /var/log/nginx/error.log"
        return 1
    fi
}

nginx_stop() {
    log_info "Stopping Nginx..."
    if is_running "$NGINX_PID"; then
        "$NGINX_BIN" -s quit
        if wait_for_stop "$NGINX_PID" 10; then
            log_ok "Nginx stopped."
        else
            log_warn "Nginx did not stop gracefully, sending SIGKILL..."
            kill -9 "$(cat "$NGINX_PID")" 2>/dev/null || true
            rm -f "$NGINX_PID"
            log_ok "Nginx killed."
        fi
    else
        log_warn "Nginx is not running."
    fi
}

nginx_reload() {
    log_info "Reloading Nginx configuration..."
    if is_running "$NGINX_PID"; then
        if ! "$NGINX_BIN" -t 2>&1; then
            log_err "Nginx configuration test failed. Not reloading."
            return 1
        fi
        "$NGINX_BIN" -s reload
        log_ok "Nginx reloaded."
    else
        log_warn "Nginx is not running. Starting instead..."
        nginx_start
    fi
}

# ── Orchestration ─────────────────────────────────────────────────────────────

start_all() {
    echo -e "\n${CYAN}═══════════════════════════════════════════════════${NC}"
    echo -e "${CYAN}  Starting all services (PostgreSQL → PHP-FPM → Nginx)${NC}"
    echo -e "${CYAN}═══════════════════════════════════════════════════${NC}\n"
    pg_start
    fpm_start
    nginx_start
    echo ""
    status_all
}

stop_all() {
    echo -e "\n${CYAN}═══════════════════════════════════════════════════${NC}"
    echo -e "${CYAN}  Stopping all services (Nginx → PHP-FPM → PostgreSQL)${NC}"
    echo -e "${CYAN}═══════════════════════════════════════════════════${NC}\n"
    nginx_stop
    fpm_stop
    pg_stop
}

restart_all() {
    stop_all
    echo ""
    sleep 2
    start_all
}

status_all() {
    echo -e "${CYAN}─── Service Status ─────────────────────────────────${NC}"

    # PostgreSQL
    if su - "$PG_USER" -c "pg_ctl -D $PG_DATA status" &>/dev/null; then
        local pg_pid
        pg_pid=$(su - "$PG_USER" -c "pg_ctl -D $PG_DATA status" 2>/dev/null | grep -oP 'PID: \K[0-9]+')
        echo -e "  PostgreSQL:  ${GREEN}● running${NC}  (PID: ${pg_pid})"
    else
        echo -e "  PostgreSQL:  ${RED}● stopped${NC}"
    fi

    # PHP-FPM
    if is_running "$PHP_FPM_PID"; then
        echo -e "  PHP-FPM:     ${GREEN}● running${NC}  (PID: $(cat "$PHP_FPM_PID"))"
    else
        echo -e "  PHP-FPM:     ${RED}● stopped${NC}"
    fi

    # Nginx
    if is_running "$NGINX_PID"; then
        echo -e "  Nginx:       ${GREEN}● running${NC}  (PID: $(cat "$NGINX_PID"))"
    else
        echo -e "  Nginx:       ${RED}● stopped${NC}"
    fi

    echo -e "${CYAN}────────────────────────────────────────────────────${NC}"
}

# ── Main ──────────────────────────────────────────────────────────────────────

case "${1:-}" in
    start)   start_all   ;;
    stop)    stop_all     ;;
    restart) restart_all  ;;
    reload)  nginx_reload ;;
    status)  status_all   ;;
    *)
        echo "Usage: $(basename "$0") {start|stop|restart|reload|status}"
        exit 1
        ;;
esac
